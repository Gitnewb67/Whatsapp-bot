# ─── WhatsApp Business API ────────────────────────────────────────────────────
# Get these from Meta Business Suite → WhatsApp → API Setup
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID_HERE
WHATSAPP_ACCESS_TOKEN=YOUR_PERMANENT_ACCESS_TOKEN_HERE
WHATSAPP_VERIFY_TOKEN=choose_any_secret_string_here

# ─── Zeev ERP ─────────────────────────────────────────────────────────────────
# Add your Zeev ERP base URL and API key when ready
ZEEV_ERP_BASE_URL=https://your-zeev-instance.com/api/v1
ZEEV_ERP_API_KEY=YOUR_ZEEV_API_KEY_HERE

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000

# Set to "true" to use real WhatsApp API and Zeev ERP.
# Leave as "false" during development — mocks are used instead.
USE_REAL_WHATSAPP=false
USE_REAL_ERP=false
